aws_region                    = "us-east-1"
project_name                  = "resource-allocation"
environment                   = "learnerlab"
preferred_availability_zone   = "us-east-1a"
ec2_instance_type             = "t3.micro"
public_key_path               = "~/.ssh/id_rsa.pub"
ec2_key_pair_name             = "resource-allocation-ec2-key"
existing_instance_profile_name = "LabInstanceProfile"
container_image_tag           = "latest"

ssh_ingress_cidr_blocks       = ["0.0.0.0/0"]
app_ingress_cidr_blocks       = ["0.0.0.0/0"]

# Create a low-cost PostgreSQL RDS instance by default.
create_rds                   = true
rds_instance_class           = "db.t3.micro"
rds_allocated_storage_gb     = 20
rds_max_allocated_storage_gb = 25
rds_storage_type             = "gp2"
rds_db_name                  = "disaster_db"
rds_username                 = "postgres"
rds_password                 = "change-me-please"
rds_backup_retention_days    = 0
rds_deletion_protection      = false

# To reuse an existing RDS instead, set create_rds = false and fill these:
# existing_rds_host              = "your-rds-endpoint"
# existing_rds_port              = 5432
# existing_rds_name              = "disaster_db"
# existing_rds_username          = "postgres"
# existing_rds_password          = "change-me"
# existing_rds_security_group_id = "sg-xxxxxxxx"

dynamodb_table_name           = "resource-allocation-idempotency"
idempotency_ttl_hours         = 24
app_port                      = 3000

powergrid_completed_queue_name      = "resource-events-powergrid-completed"
powergrid_completed_dlq_name        = "resource-events-powergrid-completed-dlq"
shelter_transporting_queue_name = "resource-events-shelter-transporting"
shelter_transporting_dlq_name = "resource-events-shelter-transporting-dlq"
request_completed_queue_name  = "resource-events-request-completed"
request_completed_dlq_name    = "resource-events-request-completed-dlq"
incident_completed_queue_name = "resource-events-incident-completed"
incident_completed_dlq_name   = "resource-events-incident-completed-dlq"

lambda_role_name              = "LabRole"
nearby_lambda_package_path    = "../dist/nearby-lambda.zip"
nearby_lambda_timeout_seconds = 10
nearby_lambda_memory_mb       = 512
lambda_log_retention_days     = 7
lambda_db_connect_timeout_ms  = 5000
lambda_db_query_timeout_ms    = 3000
lambda_db_pool_max            = 2
lambda_db_ssl_enabled         = false
dispatcher_bearer_token       = "dispatcher-dev-token"
nearby_api_throttling_burst_limit = 20
nearby_api_throttling_rate_limit  = 10
